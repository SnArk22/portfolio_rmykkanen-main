---
import Layout from "@/layouts/Layout.astro";
import Text from "@/components/Text.astro";
import { Carousel, CarouselSlide } from "@/components/ui/carousel";

import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export const getStaticPaths = async () => {
  const newsletters = await getCollection("newsletters");

  return newsletters.map((newsletter) => ({
    params: { newsletter: newsletter.id },
    props: { newsletter },
  }));
};

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/newsletters/**/*.{webp,jpg,png}",
  { eager: true },
);

const { newsletter } = Astro.props;
const { Content } = await render(newsletter);

const slug = newsletter.id;

const galleryImages = Object.entries(allImages)
  .filter(([path]) => path.includes(`/newsletters/${slug}/`))
  .map(([_, loader]) => loader.default);
---

<Layout>
  <Text as="h1" variant="mainHeading">{newsletter.data.title}</Text>

  <Content />

  {
    galleryImages.length > 0 && (
      <Carousel class="gap-4 p-2" align="center">
        {galleryImages.map((image) => (
          <CarouselSlide>
            <Image
              src={image}
              alt={"project gallery image"}
              class="w-120 h-96 object-cover rounded-lg"
            />
          </CarouselSlide>
        ))}
      </Carousel>
    )
  }
</Layout>
