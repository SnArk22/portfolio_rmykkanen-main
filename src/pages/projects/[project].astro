---
import Layout from "@/layouts/Layout.astro";
import Text from "@/components/Text.astro";
import {
  Card as CardRoot,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
  CardMedia,
  CardFooter,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Carousel, CarouselSlide } from "@/components/ui/carousel";
import Card from "@/components/Card.astro";

import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export const getStaticPaths = async () => {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { project: project.id },
    props: { project },
  }));
};

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/**/*.{webp,jpg,png}",
  { eager: true },
);

const { project } = Astro.props;
const { Content } = await render(project);

const slug = project.id;

if (!allImages[`/src/assets/projects/${slug}/featured.webp`]) {
  throw new Error(
    `No featured image found for project ${slug}. Add a an image titled 'featured.webp' to folder '/src/assets/projects/${slug}/'`,
  );
}

const featuredImage =
  allImages[`/src/assets/projects/${slug}/featured.webp`].default;

const galleryImages = Object.entries(allImages)
  .filter(
    ([path]) =>
      path.includes(`/projects/${slug}/`) && !path.endsWith("featured.webp"),
  )
  .map(([_, loader]) => loader.default);
---

<Layout>
  <Card item={project} variant="single" />

  <Content />

  {
    galleryImages.length > 0 && (
      <Carousel class="gap-4 p-2" align="center">
        {galleryImages.map((image) => (
          <CarouselSlide>
            <Image
              src={image}
              alt={"project gallery image"}
              class="w-120 h-96 object-cover rounded-lg"
            />
          </CarouselSlide>
        ))}
      </Carousel>
    )
  }
</Layout>
