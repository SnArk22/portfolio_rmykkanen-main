---
import Layout from "@/layouts/Layout.astro";
import Text from "@/components/Text.astro";
import Card from "@/components/Card.astro";
import { getCollection } from "astro:content";
import TagCloud from "@/components/TagCloud.astro";

const projects = await getCollection("projects");

const allTags = new Set(projects.flatMap((project) => project.data.tags ?? []));
---

<Layout>
  <div class="flex flex-col-2 gap-10 max-w-2xl mx-auto px-4  justify-center">
      <Text as="h1" variant="minorHeading" class="text-center">
        Projects
      </Text>
      <Text as="h2" variant="subHeading" class:list={"text-center"}>
        Select a cateogory to view projects in that category
      </Text>
  </div>
  <hr class="my-0 border-t-4 border-border border-chart-4" />
  <div class="relative left-1/2 w-screen -translate-x-1/2 px-4">
    <div class="mx-auto max-w-7xl">
      <div class="pt-0 pb-6">
        <TagCloud tags={[...allTags]} />
      </div>
      <div class="columns-1 gap-8 lg:columns-3">
        {projects.map((project) => <Card item={project} variant="grid" />)}
      </div>
    </div>
  </div>
</Layout>
